{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "shell:allow-execute",
    "shell:allow-open",
    "updater:default",
    "process:allow-restart",
    "process:allow-exit"
  ]
}
